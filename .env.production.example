NODE_ENV=production
HOST=0.0.0.0
PORT=8080
TRUST_PROXY=1
PUBLIC_ORIGIN=https://emulator.example.com
REQUIRE_HTTPS=true

SESSION_COOKIE_NAME=sce_session
COOKIE_SECURE=true
JWT_TTL_MINUTES=480
JWT_SECRET=replace-with-at-least-32-random-characters
AUTH_USERS_FILE=/run/secrets/users.json

ADB_PATH=adb
ADB_SERVER_SOCKET=tcp:android-worker:5037
STREAM_FPS=4
MAX_APK_SIZE_MB=500

CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=120000
CLAMAV_REQUIRED=true

UPLOAD_DIR=/app/uploads
UPLOAD_RETENTION_MINUTES=30
RETENTION_SWEEP_MINUTES=15

AUDIT_LOG_DIR=/app/data/audit
AUDIT_RETENTION_DAYS=90
AUDIT_HMAC_KEY=replace-with-a-different-32-character-random-key

LOGIN_RATE_LIMIT=8
API_RATE_LIMIT=600
CONTROL_RATE_LIMIT=300
UPLOAD_RATE_LIMIT=10
