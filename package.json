{
  "name": "singh-cloud-emulator",
  "version": "0.5.0",
  "private": true,
  "description": "Production-grade mobile cloud emulator, testing, profiling and development platform",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
