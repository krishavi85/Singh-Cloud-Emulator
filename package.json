    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "nodemailer": "^7.0.0",
    "pg": "^8.0.0",
    "prom-client": "^15.0.0",
    "redis": "^5.0.0",
    "tar": "^7.0.0",
    "ws": "^8.18.3"
