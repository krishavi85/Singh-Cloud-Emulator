NODE_ENV=production
HOST=0.0.0.0
PORT=8080
TRUST_PROXY=1
PUBLIC_ORIGIN=https://emulator.example.com
REQUIRE_HTTPS=true
COOKIE_SECURE=true
JWT_SECRET=generate-a-strong-random-value
AUDIT_HMAC_KEY=generate-a-different-random-value
AUTH_USERS_FILE=/run/secrets/users.json

DATABASE_URL=postgresql://singh_cloud:change-me@postgres:5432/singh_cloud
REDIS_URL=redis://:change-me@redis:6379/0
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=singh-cloud-artifacts
S3_ACCESS_KEY_ID=singh-cloud
S3_SECRET_ACCESS_KEY=change-me
S3_FORCE_PATH_STYLE=true
S3_CREATE_BUCKET=true

CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_REQUIRED=true
UPLOAD_DIR=/app/uploads
AUDIT_LOG_DIR=/app/data/audit
WORKSPACE_ROOT=/app/data/workspaces
PROFILE_ARTIFACT_DIR=/app/data/profiles

SCHEDULER_SWEEP_MS=10000
QUEUE_REFRESH_MS=15000
WORKER_STALE_MS=90000
BUILD_STALE_MS=1800000
CAPTURE_STALE_MS=120000

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=change-me
SMTP_PASSWORD=change-me
SMTP_FROM=noreply@example.com

LAGO_API_URL=http://lago-api:3000
LAGO_API_KEY=change-me
LAGO_WEBHOOK_HMAC_KEY=change-me

METRICS_BEARER_TOKEN=change-me
GIT_PUSH_ENABLED=false

WORKER_API_BASE=https://emulator.example.com
BUILD_WORKER_API_KEY=sce_live_replace
CAPTURE_WORKER_API_KEY=sce_live_replace
ANDROID_COMMANDLINE_TOOLS_URL=
