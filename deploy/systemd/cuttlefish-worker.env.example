SCE_API_BASE=https://emulator.example.com
SCE_API_KEY=sce_live_replace_with_workers_write_key
SCE_WORKER_ID=cuttlefish-host-01
SCE_POLL_MS=3000

ADB_PATH=/usr/bin/adb
CUTTLEFISH_LAUNCHER=/usr/bin/launch_cvd
CUTTLEFISH_STOPPER=/usr/bin/stop_cvd
CUTTLEFISH_WORK_ROOT=/var/lib/singh-cuttlefish
CUTTLEFISH_PUBLIC_HOST=cuttlefish.example.com
CUTTLEFISH_WEBRTC_PORT=8443
CUTTLEFISH_SESSION_URL_TEMPLATE=https://cuttlefish.example.com/client.html?session={sessionId}&device={workerId}&instance={instance}
CUTTLEFISH_EXTRA_ARGS=--enable_audio=true
