# Control-plane service URLs
CODE_SERVER_BASE_URL=http://ide:8080
CODE_SERVER_HEALTH_PATH=/healthz
CODE_SERVER_SESSION_URL_TEMPLATE=https://ide.example.com/?folder=/workspace/{workspaceId}

APPIUM_BASE_URL=http://appium:4723
APPIUM_HEALTH_PATH=/status

MITMPROXY_WEB_URL=https://proxy.example.com
MITMPROXY_HEALTH_PATH=/
MITMPROXY_DEVICE_HOST=mitmproxy
MITMPROXY_DEVICE_PORT=8080
MITMPROXY_CERTIFICATE_URL=http://mitm.it
MITMPROXY_HAR_URL_TEMPLATE=https://proxy.example.com/captures/{captureId}.har
MITMPROXY_SESSION_URL_TEMPLATE=https://proxy.example.com/?session={sessionId}

PERFETTO_UI_URL=https://ui.perfetto.dev
PERFETTO_HEALTH_PATH=/
PERFETTO_SESSION_URL_TEMPLATE=https://ui.perfetto.dev
PROFILE_ARTIFACT_DIR=/app/data/profiles
PROFILE_RETENTION_HOURS=24

CUTTLEFISH_WEBRTC_BASE_URL=https://cuttlefish.example.com
CUTTLEFISH_HEALTH_PATH=/
CUTTLEFISH_SESSION_URL_TEMPLATE=https://cuttlefish.example.com/client.html?session={sessionId}&device={workerId}

IOS_SIMULATOR_BASE_URL=https://ios-worker.example.com
IOS_SIMULATOR_HEALTH_PATH=/health
IOS_SIMULATOR_SESSION_URL_TEMPLATE=https://ios-worker.example.com/session/{sessionId}
IOS_PROFILER_SESSION_URL_TEMPLATE=https://ios-worker.example.com/instruments/{sessionId}

DEBUG_ADAPTER_BASE_URL=http://debug-adapter:4711
DEBUG_ADAPTER_HEALTH_PATH=/health
DEBUG_ADAPTER_SESSION_URL_TEMPLATE=https://debug.example.com/session/{sessionId}

# Sidecar stack secrets and ports
CODE_SERVER_PASSWORD=replace-with-a-long-random-password
CODE_SERVER_PORT=8444
ANDROID_COMMANDLINE_TOOLS_URL=
APPIUM_PORT=4723
MITMPROXY_WEB_PORT=8081

TURN_REALM=emulator.example.com
TURN_USERNAME=singh-turn
TURN_PASSWORD=replace-with-a-long-random-password
TURN_EXTERNAL_IP=203.0.113.10

POSTGRES_DB=singh_cloud
POSTGRES_USER=singh_cloud
POSTGRES_PASSWORD=replace-with-a-long-random-password
REDIS_PASSWORD=replace-with-a-long-random-password
MINIO_ROOT_USER=singh-cloud
MINIO_ROOT_PASSWORD=replace-with-a-long-random-password
MINIO_CONSOLE_PORT=9001
